{
  "name": "node",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "build": "tsc",
    "batch": "node dist/batch/index.js",
    "batch:collect": "ts-node src/batch/index.ts collect",
    "batch:ogp": "ts-node src/batch/index.ts ogp",
    "batch:likes": "ts-node src/batch/index.ts likes",
    "batch:delete": "ts-node src/batch/index.ts delete",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/TechArchiveTable  --dataSource src/config/migrationDataSource.ts",
    "migration:run": "npm run typeorm -- migration:run --dataSource src/config/migrationDataSource.ts",
    "migration:revert": "npm run typeorm -- migration:revert --dataSource src/config/migrationDataSource.ts",
    "seed:run": "ts-node ./src/database/seeders/index.ts",
    "db:reset": "ts-node src/database/reset.ts",
    "db:fresh": "npm run db:reset && npm run migration:generate && npm run migration:run && npm run seed:run",
    "lint": "eslint .",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "check": "npm run lint && npm run format",
    "lint:fix": "eslint . --fix",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "fix": "npm run lint:fix && npm run format:fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.98.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  }
}
